{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:pareto-support-proof:trace:1.0.0",
  "title": "Pareto support generation trace v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "schema_version",
    "canonicalisation",
    "result",
    "iterations"
  ],
  "properties": {
    "format": {
      "const": "pareto-support-generation-trace"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "canonicalisation": {
      "const": "psp-json-c14n-1"
    },
    "result": {
      "enum": [
        "nonnegative_weight_supportable",
        "positive_weight_supportable",
        "nonnegative_weight_unsupported"
      ]
    },
    "iterations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    }
  }
}
